<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>New Password</title>
    <link rel="stylesheet" href="/css/reset.css">
    <link rel="stylesheet" href="/css/auth.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>

<body>

<div class="auth-container">

    <h1 id="update-password">Update Your Password</h1>

    <form action="/new-password" method="POST" id="a-form">

        <div class="input-group">
            <label>Email</label>
            <input type="email" id="email" name="email" placeholder="Enter your email" required>
        </div>

        <div class="input-group password-group">
            <label>New Password</label>

            <div class="password-wrapper">
                <input type="password" id="setNewPassword" name="password" placeholder="Enter password" required>

                <i class="fa-solid fa-eye toggle-password"></i>
            </div>
            <p id="password-error" class="error"></p>
        </div>

        <div class="input-group password-group">
            <label>Confirm New Password</label>

            <div class="password-wrapper">
                <input type="password" id="confirmNewPassword" name="password1" placeholder="Confirm password" required>

                <i class="fa-solid fa-eye toggle-password"></i>
            </div>
            <p id="confirm-error" class="error"></p>
        </div>

        <p id="message"></p>

        <button type="submit">Confirm</button>

        <p class="switch">
            Already have an account?
            <a href="/login">Login</a>
        </p>

    </form>

</div>

    <script type="module" src="../dist/auth.js"></script>
</body>
</html>