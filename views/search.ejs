<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Recipes — Search</title>
    <link rel="stylesheet" href="/css/reset.css">
    <link rel="stylesheet" href="/css/search.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>

    <%- include('partials/header') %>

    <div class="hero">
        <div class="hero-eyebrow">Discover something delicious</div>
        <h1>What are you<br>craving today?</h1>
        <p class="hero-sub">Search thousands of recipes from around the world</p>

        <div class="search-container">
            <input type="text" class="search-input" placeholder='Try "pasta", "chicken", "shawarma"...'>
            <button class="search-btn">Search</button>
        </div>

        <div class="search-tags">
            <button class="search-tag">Pasta</button>
            <button class="search-tag">Chicken</button>
            <button class="search-tag">Seafood</button>
            <button class="search-tag">Vegetarian</button>
            <button class="search-tag">Cake</button>
            <button class="search-tag">Beef</button>
        </div>
    </div>

    <!-- <button id="openModal">Open</button> -->
    <div class="modal" id="modal">
        <div class="modal-inner">
            <h2 id="error-msg">Recipe Successfully Added!</h2>
             <div class="modal-btn">
                <button id="closeModal">Close</button>
            </div>
        </div>
    </div>

    <div class="section-label" id="results-label" style="display: none;">Results</div>

    <section class="cards">
        <div class="filter-bar">
            <select id="rating-filter">
            <option value="">Sort by Rating</option>
            <option value="low">Rating: Low to High</option>
            <option value="high">Rating: High to Low</option>
            </select>
        </div>
        
        <div class="part part1"></div>
    </section>

    <script type="module" src="../dist/search.js"></script>
</body>
</html>
